[Unit]
Description=HEDGE Export Instruments to Excel/CSV (support; not part of trading loop)

[Service]
Type=oneshot
User=teckz
Group=teckz
WorkingDirectory=/home/teckz/Documents/HEDGE
EnvironmentFile=-/home/teckz/Documents/HEDGE/.env
ExecStart=/home/teckz/Documents/HEDGE/venv/bin/python -m core.services.export_instruments
Restart=no
StandardOutput=journal
StandardError=journal
